	charset Subset1 = 1-896 897-2330 3012-3209\3 8310-9347\3 2331-3011\3 9348-9692\3 7356-8309\3 11367-13190\3 6216-7355\3 9693-9989\3 9990-11366\3 3210-4748\3 4749-5432\3 5433-6215\3 13713-15157 13191-13712\3 13192-13712\3;
	charset Subset2 = 3211-4748\3 4750-5432\3 3013-3209\3 11368-13190\3 8311-9347\3 2332-3011\3 9991-11366\3 9349-9692\3 7357-8309\3 5434-6215\3 6217-7355\3 9694-9989\3;
	charset Subset3 = 5435-6215\3 9992-11366\3 9350-9692\3 9695-9989\3 6218-7355\3 8312-9347\3 11369-13190\3 7358-8309\3 3014-3209\3 4751-5432\3 2333-3011\3 3212-4748\3;
	charset Subset4 = 13193-13712\3;

	partition PartitionFinder = 4:Subset1, Subset2, Subset3, Subset4;
	set partition=PartitionFinder;

	lset applyto=(1) nst=6 rates=invgamma;
	lset applyto=(2) nst=6 rates=invgamma;
	lset applyto=(3) nst=6 rates=invgamma;
	lset applyto=(4) nst=6 rates=invgamma;

	prset applyto=(all) ratepr=variable;
	unlink statefreq=(all) revmat=(all) shape=(all) pinvar=(all) tratio=(all);
	unlink brlens=(all);


	mcmc nruns=2 nchains=4 ngen=10000000 samplefreq=1000 printfreq=1000 diagnfreq=10000 starttree=random;
	sump relburnin=no burnin=2500 nruns=2;
	sumt relburnin=no burnin=2500 nruns=2 contype=halfcompat;

end;
